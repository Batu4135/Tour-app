{
  "name": "nord-pack-tour-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema prisma/schema.prisma && next build",
    "build:vercel": "prisma migrate deploy --schema prisma/schema.prisma && npm run build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "db:generate": "npm run db:generate:cloud && npm run db:generate:local",
    "db:generate:cloud": "prisma generate --schema prisma/schema.prisma",
    "db:generate:local": "prisma generate --schema prisma/local.schema.prisma",
    "db:push": "npm run db:push:cloud",
    "db:push:cloud": "prisma db push --schema prisma/schema.prisma",
    "db:push:local": "prisma db push --schema prisma/local.schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:seed:realistic": "tsx scripts/seed-realistic.ts",
    "db:connect": "tsx scripts/db-connect.ts",
    "db:dump": "tsx scripts/db-dump.ts",
    "db:restore": "tsx scripts/db-restore.ts",
    "import:products": "tsx scripts/import-products.ts",
    "import:customers": "tsx scripts/import-customers.ts",
    "backup": "tsx scripts/backup-db.ts",
    "pull:local": "prisma generate --schema prisma/local.schema.prisma && tsx scripts/pull-latest-to-local.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^0.453.0",
    "next": "^14.2.16",
    "next-intl": "^3.20.0",
    "next-pwa": "^5.6.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.16",
    "postcss": "^8.4.47",
    "prisma": "^5.19.1",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
